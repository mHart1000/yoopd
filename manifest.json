{
  "manifest_version": 3,
  "name": "Yoopd",
  "version": "1.0",
  "icons": {
    "48": "icons/yoopd-logo.png",
    "128": "icons/yoopd-logo.png"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }],
  "action": {
    "default_icon": "icons/yoopd-logo.png"
  }
}
